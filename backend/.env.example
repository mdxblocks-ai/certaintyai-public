ANTHROPIC_API_KEY=sk-ant-paste-yours-here
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
DATABASE_URL=sqlite:///./data/certaintyai.db

# ----- LLM provider abstraction (local dev override) -----
# Default in code is "anthropic" (matches CONTEXT.md §11). Set to "openai"
# if you only have an OpenAI key. Switching back to claude-sonnet-4-6 is
# a one-line revert in this file.
LLM_PROVIDER=anthropic
OPENAI_API_KEY=sk-paste-yours-here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6
